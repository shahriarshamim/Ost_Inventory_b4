
@{
    ViewBag.Title = "Login";
    Layout = "~/Views/Shared/_LayoutAuth.cshtml";
}

<div style="border: 1px solid beige;; width: 400px; height: 500px; position: fixed; top: 0px; left: 0px; right: 0px; margin: auto; bottom: 0px; background: #ffd800">
    <div style="width: 350px; height: 450px; background: #ffda00; padding: 5px; position: absolute; top: 0px; right: 0px; left: 0px; bottom: 0px; margin: auto">
        <h3 style="text-align:center">Login</h3>
        <h4 style="text-align:center;color:#808080">Have an Account?</h4>
        <input style="width:98%;height:30px;" placeholder="User Name"/><br />
        <input style="width:98%;height:30px;margin-top:2px;" placeholder="Password"/>
        <input type="submit" value="Log In" style="width:100%;height:30px;margin-top:2px" />
    </div>
</div>

