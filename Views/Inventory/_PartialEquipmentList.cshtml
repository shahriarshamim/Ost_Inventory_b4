@using Ost_Inventory_b4.Models;
@{
    BaseEquipment baseEquipment = new BaseEquipment();
    List<BaseEquipment> equipments = baseEquipment.LstEquipment();
}
    <div class="card">
        <div class="card-header">
            Equipment List
            <a href="#" class="btn btn-sm btn-primary" onclick="ShowModal()">Add New</a>
        </div>
        <div class="card-body">
            <div style="width:100%;height:400px;overflow:auto">
                <table class="ws-table-all" style="width:100%;">
                    <tr>
                        <th>EquipmentId</th>
                        <th>EquipmentName</th>
                        <th>Quantity</th>
                        <th>Stock</th>
                        <th>EntryDate</th>
                        <th>ReceiveDate</th>
                    </tr>
                    @foreach (BaseEquipment obj in equipments)
                    {
                        <tr>
                            <td>@obj.EquipmentId</td>
                            <td>@obj.EquipmentName</td>
                            <td>@obj.Quantity</td>
                            <td>@obj.Stock</td>
                            <td>@obj.EntryDate.ToString("dd/MM/yyyy")</td>
                            <td>@obj.ReceiveDate.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </table>
            </div>
        </div>
    </div>